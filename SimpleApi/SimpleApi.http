@SimpleApi_HostAddress = http://localhost:5258
@SimpleApi_HttpsAddress = https://localhost:7102

### Get All Products
GET {{SimpleApi_HttpsAddress}}/api/products
Accept: application/json

### Get a Specific Product by ID
GET {{SimpleApi_HttpsAddress}}/api/products/1
Accept: application/json

### Create a New Product
POST {{SimpleApi_HttpsAddress}}/api/products
Content-Type: application/json

{
  "name": "Sample Product",
  "description": "This is a test product",
  "price": 49.99
}

### Update an Existing Product
PUT {{SimpleApi_HttpsAddress}}/api/products/1
Content-Type: application/json

{
  "name": "Updated Product Name",
  "description": "Updated description",
  "price": 59.99
}

### Delete a Product
DELETE {{SimpleApi_HttpsAddress}}/api/products/1

